# Fanvue OAuth
OAUTH_CLIENT_ID=YOUR_FANVUE_CLIENT_ID
OAUTH_CLIENT_SECRET=YOUR_FANVUE_CLIENT_SECRET
OAUTH_SCOPES=read:self read:chat write:chat read:fan read:insights
OAUTH_REDIRECT_URI=https://YOUR_DOMAIN/api/oauth/callback
BASE_URL=https://YOUR_DOMAIN
OAUTH_ISSUER_BASE_URL=https://auth.fanvue.com
API_BASE_URL=https://api.fanvue.com

# Session
SESSION_COOKIE_NAME=fvsession
SESSION_SECRET=use-a-long-random-secret-at-least-16-chars

# Discord
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN
DISCORD_GUILD_ID=YOUR_DISCORD_GUILD_ID
DISCORD_ROLE_ID=YOUR_DISCORD_ROLE_ID

# Optional worker settings
DISCORD_SYNC_POLL_INTERVAL_SECONDS=20
DISCORD_BINDINGS_RECONCILE_INTERVAL_HOURS=24
FANVUE_API_VERSION=2025-06-26
